datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String     @id @default(cuid())
  employeeId  String     @unique
  name        String
  password    String
  phone       String?
  email       String?
  address     String?
  postalCode  String?
  status      String     @default("啟動")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  roles      UserRole[]
  createdBy  String?
  creator    User?      @relation("UserCreator", fields: [createdBy], references: [id])
  createdUsers User[]   @relation("UserCreator")

  @@map("users")
}

model Role {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  org         String    @default("頤安(逸麗)護老院")
  description String?
  type        String    @default("普通角色")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model RolePermission {
  id       String @id @default(cuid())
  roleId   String
  module   String
  canView  Boolean @default(false)
  canEdit  Boolean @default(false)

  role     Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module])
  @@map("role_permissions")
}

model UserRole {
  userId    String
  roleId    String
  isDefault Boolean @default(true)

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Customer {
  id            String   @id
  careId        String
  name          String
  bed           String?
  gender        String
  idCard        String
  birth         DateTime
  balance       Float    @default(0)
  phone         String?
  status        String   @default("在院")
  basicFee      Float    @default(0)
  subsidy       Float    @default(0)
  deposit       Float    @default(0)
  admissionDate DateTime?
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  family         Family[]
  serviceRecords ServiceRecord[]
  bills          Bill[]
  prepaidRecords PrepaidRecord[]
  billPublishes  BillPublish[]
  cashRecords    CashRecord[]

  @@map("customers")
}

model Family {
  id         String  @id @default(cuid())
  customerId String
  name       String
  phone      String
  isMain     Boolean @default(false)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("family")
}

model Service {
  id        String   @id
  type      String
  name      String
  price     Float
  stock     Int?
  isCommon  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventoryRecords InventoryRecord[]
  serviceRecords   ServiceRecord[]

  @@map("services")
}

model InventoryRecord {
  id        String   @id @default(cuid())
  itemId    String
  date      DateTime
  type      String
  reason    String
  qty       Int
  createdAt DateTime @default(now())

  service Service @relation(fields: [itemId], references: [id])

  @@map("inventory_records")
}

model ServiceRecord {
  recordId   String   @id @default(cuid())
  customerId String
  date       DateTime
  type       String
  serviceId  String
  name       String
  qty        Int
  amount     Float
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  service Service  @relation(fields: [serviceId], references: [id])

  @@map("service_records")
}

model Bill {
  id          String   @id @default(cuid())
  customerId  String
  month       String
  basicFee    Float
  serviceFee  Float    @default(0)
  totalFee    Float
  prepaid     Float    @default(0)
  debt        Float    @default(0)
  status      String   @default("待繳費")
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([customerId, month])
  @@map("bills")
}

model PrepaidRecord {
  id          String   @id @default(cuid())
  customerId  String
  amount      Float
  date        DateTime
  note        String?
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@map("prepaid_records")
}

model BillPublish {
  id          String   @id @default(cuid())
  customerId  String
  month       String
  totalFee    Float
  publishedAt DateTime @default(now())
  publishedBy String?
  note        String?

  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([customerId, month])
  @@map("bill_publishes")
}

model CashRecord {
  id          String   @id @default(cuid())
  customerId  String
  type        String   // '收入' | '支出'
  amount      Float
  date        DateTime
  reason      String
  collectedBy String?
  note        String?
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@map("cash_records")
}
